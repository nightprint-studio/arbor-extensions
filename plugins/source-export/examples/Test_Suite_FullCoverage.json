              "position": "after",
              "content": "\nPrerequisites: none.\n"
            }
          },
          {
            "id": "stp_H0_verify",
            "name": "Inserted content must be present",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "guide.md", "pattern": "Prerequisites: none.", "negate": true }
          }
        ]
      },

      {
        "id": "stg_I0_json",
        "name": "18 · json_edit (LuaOp, serde_json)",
        "mode": "sequential",
        "max_parallel": null,
        "steps": [
          {
            "id": "stp_I0_seed",
            "name": "Seed data.json",
            "kind": "create_file",
            "allow_failure": false,
            "params": {
              "path": "structured/data.json",
              "content": "{\n  \"name\": \"arbor-test\",\n  \"version\": \"1.0.0\",\n  \"server\": { \"host\": \"localhost\", \"port\": 8080 },\n  \"tags\": [\"alpha\", \"beta\"]\n}\n",
              "overwrite": true
            }
          },
          {
            "id": "stp_I0_edit_top",
            "name": "Bump $.version",
            "kind": "json_edit",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "jpath": "$.version", "value": "$VERSION_NEW" }
          },
          {
            "id": "stp_I0_edit_nested",
            "name": "Change server.host (dotted, no $)",
            "kind": "json_edit",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "jpath": "server.host", "value": "prod.internal" }
          },
          {
            "id": "stp_I0_edit_port_int",
            "name": "Change server.port to number (JSON promote)",
            "kind": "json_edit",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "jpath": "server.port", "value": "443" }
          },
          {
            "id": "stp_I0_edit_array",
            "name": "Set tags[0] to 'stable'",
            "kind": "json_edit",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "jpath": "tags.0", "value": "stable" }
          },
          {
            "id": "stp_I0_add_new",
            "name": "Create missing path $.meta.kind",
            "kind": "json_edit",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "jpath": "$.meta.kind", "value": "export" }
          },
          {
            "id": "stp_I0_verify_bump",
            "name": "Old version 1.0.0 must be gone",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "pattern": "1\\.0\\.0", "negate": false }
          },
          {
            "id": "stp_I0_verify_new_key",
            "name": "meta.kind must now be present",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/data.json", "pattern": "\"kind\"", "negate": true }
          }
        ]
      },

      {
        "id": "stg_J0_yaml",
        "name": "19 · yaml_edit (LuaOp, serde_yaml)",
        "mode": "sequential",
        "max_parallel": null,
        "steps": [
          {
            "id": "stp_J0_seed",
            "name": "Seed application.yaml",
            "kind": "create_file",
            "allow_failure": false,
            "params": {
              "path": "structured/application.yaml",
              "content": "service:\n  name: demo\n  version: 1.0.0\n  features:\n    auth: true\n    metrics: false\n",
              "overwrite": true
            }
          },
          {
            "id": "stp_J0_edit_version",
            "name": "service.version → $VERSION_NEW",
            "kind": "yaml_edit",
            "allow_failure": false,
            "params": { "path": "structured/application.yaml", "ypath": "service.version", "value": "$VERSION_NEW" }
          },
          {
            "id": "stp_J0_edit_bool",
            "name": "service.features.metrics → true (bool promote)",
            "kind": "yaml_edit",
            "allow_failure": false,
            "params": { "path": "structured/application.yaml", "ypath": "service.features.metrics", "value": "true" }
          },
          {
            "id": "stp_J0_add_key",
            "name": "Add service.description (missing key)",
            "kind": "yaml_edit",
            "allow_failure": false,
            "params": { "path": "structured/application.yaml", "ypath": "service.description", "value": "Auto-generated by test suite" }
          },
          {
            "id": "stp_J0_verify",
            "name": "Old 1.0.0 must be gone",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/application.yaml", "pattern": "1\\.0\\.0", "negate": false }
          }
        ]
      },

      {
        "id": "stg_K0_toml",
        "name": "20 · toml_edit (LuaOp, toml crate)",
        "mode": "sequential",
        "max_parallel": null,
        "steps": [
          {
            "id": "stp_K0_seed",
            "name": "Seed Cargo-like TOML",
            "kind": "create_file",
            "allow_failure": false,
            "params": {
              "path": "structured/Cargo.test.toml",
              "content": "[package]\nname = \"arbor-test\"\nversion = \"1.0.0\"\nedition = \"2021\"\n\n[dependencies]\nserde = \"1\"\n",
              "overwrite": true
            }
          },
          {
            "id": "stp_K0_edit_version",
            "name": "package.version → $VERSION_NEW",
            "kind": "toml_edit",
            "allow_failure": false,
            "params": { "path": "structured/Cargo.test.toml", "tpath": "package.version", "value": "$VERSION_NEW" }
          },
          {
            "id": "stp_K0_add_author",
            "name": "Add missing package.authors (array)",
            "kind": "toml_edit",
            "allow_failure": false,
            "params": { "path": "structured/Cargo.test.toml", "tpath": "package.authors", "value": "[\"Arbor Test\"]" }
          },
          {
            "id": "stp_K0_verify",
            "name": "Old version must be gone",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/Cargo.test.toml", "pattern": "version = \"1\\.0\\.0\"", "negate": false }
          }
        ]
      },

      {
        "id": "stg_L0_xml",
        "name": "21 · xml_edit (LuaOp, quick-xml)",
        "mode": "sequential",
        "max_parallel": null,
        "steps": [
          {
            "id": "stp_L0_seed",
            "name": "Seed structured/pom.test.xml",
            "kind": "create_file",
            "allow_failure": false,
            "params": {
              "path": "structured/pom.test.xml",
              "content": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project>\n  <modelVersion>4.0.0</modelVersion>\n  <groupId>com.example</groupId>\n  <artifactId>arbor-test</artifactId>\n  <version>1.0.0</version>\n  <build>\n    <plugin id=\"jar\" version=\"3.0.0\" />\n  </build>\n</project>\n",
              "overwrite": true
            }
          },
          {
            "id": "stp_L0_edit_abs",
            "name": "Absolute path: /project/version → $VERSION_NEW",
            "kind": "xml_edit",
            "allow_failure": false,
            "params": { "path": "structured/pom.test.xml", "xpath": "/project/version", "value": "$VERSION_NEW" }
          },
          {
            "id": "stp_L0_edit_attr",
            "name": "Attribute: //plugin/@version → 4.0.0",
            "kind": "xml_edit",
            "allow_failure": false,
            "params": { "path": "structured/pom.test.xml", "xpath": "//plugin/@version", "value": "4.0.0" }
          },
          {
            "id": "stp_L0_edit_any",
            "name": "Anywhere: //artifactId → arbor-renamed",
            "kind": "xml_edit",
            "allow_failure": false,
            "params": { "path": "structured/pom.test.xml", "xpath": "//artifactId", "value": "arbor-renamed" }
          },
          {
            "id": "stp_L0_verify",
            "name": "Old version must be gone",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/pom.test.xml", "pattern": "<version>1\\.0\\.0</version>", "negate": false }
          },
          {
            "id": "stp_L0_verify_attr",
            "name": "Plugin version attribute must now be 4.0.0",
            "kind": "assert_file_not_contains",
            "allow_failure": false,
            "params": { "path": "structured/pom.test.xml", "pattern": "version=\"4\\.0\\.0\"", "negate": true }
          }
        ]
      },

      {
        "id": "stg_ZZ_git",
        "name": "22 · Git (commit / tag / checkout)",
        "mode": "sequential",
        "max_parallel": null,
        "steps": [
          {
            "id": "stp_ZZ_git_config",
            "name": "Set local git identity",
            "kind": "shell_command",
            "allow_failure": true,
            "params": {
              "command": "git config user.email arbor-test@arbor.local && git config user.name Arbor Test",
              "cwd": "$OUTPUT_PATH"
            }
          },
          {
            "id": "stp_ZZ_dirty_before",
            "name": "Workdir must be dirty now",
            "kind": "assert_branch_clean",
            "allow_failure": false,
            "params": { "cwd": "$OUTPUT_PATH", "negate": true }
          },
          {
            "id": "stp_ZZ_commit",
            "name": "git commit -m (add -A)",
            "kind": "git_commit",
            "allow_failure": true,
            "params": {
              "cwd": "$OUTPUT_PATH",
              "message": "source-export test suite — run $RUN_ID",
              "author": "",
              "all": true,
              "allow_empty": false
            }
          },
          {
            "id": "stp_ZZ_clean_after",
            "name": "Workdir must be clean after commit",
            "kind": "assert_branch_clean",
            "allow_failure": true,
            "params": { "cwd": "$OUTPUT_PATH", "negate": false }
          },
          {
            "id": "stp_ZZ_tag",
            "name": "Tag the test run",
            "kind": "git_tag",
            "allow_failure": true,
            "params": {
              "cwd": "$OUTPUT_PATH",
              "name": "source-export-test-$RUN_ID",
              "message": "",
              "force": false
            }
          },
          {
            "id": "stp_ZZ_checkout",
            "name": "Create + switch to test branch",
            "kind": "git_checkout",
            "allow_failure": true,
            "params": { "cwd": "$OUTPUT_PATH", "branch": "arbor/test-$RUN_ID", "create": true }
          },
          {
            "id": "stp_ZZ_submodule",
            "name": "submodule update (no-op if none)",
            "kind": "git_submodule_update",
            "allow_failure": true,
            "params": { "cwd": "$OUTPUT_PATH" }
          }
        ]
      }
    ]
  }
}
